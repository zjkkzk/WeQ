# WeQ — 本地测试/探针脚本配置
# ============================================================================
# packages/*/test 下的集成脚本会读取本文件。复制一份为 `.env` 并填入你自己的
# QQ 数据目录与数据库密钥即可运行（`.env` 已被 .gitignore 忽略，不会进仓库）。
#
#   cp .env.example .env
#
# 说明：
#   - 所有 *.db 路径都从 WEQ_TEST_QQ_ROOT（nt_qq 目录）自动派生，通常只需配这一项。
#   - 真实环境变量优先级高于本文件，可临时覆盖：
#       WEQ_TEST_DB_KEY=xxx pnpm --filter @weq/db test:group-msg
# ============================================================================

# ---- 必填 ------------------------------------------------------------------

# QQ 数据目录的 nt_qq 根目录（其下应包含 nt_db/ 与 nt_data/）。
#   Windows 示例:  D:\Tencent Files\1234567890\nt_qq
#   Linux 示例:    /home/you/.config/QQ/nt_qq
WEQ_TEST_QQ_ROOT=

# SQLCipher 数据库密钥。可用 packages/native 的 clientkey/pskey 脚本或
# 抓取工具从运行中的 QQ 获取。
WEQ_TEST_DB_KEY=

# 被测账号的 QQ 号。
WEQ_TEST_UIN=

# ---- 选填 ------------------------------------------------------------------

# 被测账号的编码 uid（形如 u_xxxxxxxx）。部分脚本需要。
WEQ_TEST_UID=

# 覆盖单个数据库路径（一般无需设置，默认从 WEQ_TEST_QQ_ROOT 派生）。
# WEQ_TEST_DB_PATH=
# WEQ_TEST_PROFILE_DB_PATH=
# WEQ_TEST_FTS_DB_PATH=

# 消息搜索脚本的关键词（默认「你好」）。
# WEQ_TEST_KEYWORD=

# 只针对单个会话时的对端 id（如 2_673646675 / 群号）。
# WEQ_PEER=

# dump 脚本要查看的消息 id，逗号分隔。
# WEQ_TEST_MSG_IDS=

# 伪造「WeQ助手」测试数据用的 uid/uin（默认已内置占位值）。
# WEQ_FAKE_UID=
# WEQ_FAKE_UIN=

# ---- 破坏性脚本的写入开关（默认关闭，仅在明确需要时置 1）--------------------
# WEQ_DRY_RUN=1        # 只读预演，不写库
# WEQ_RESTORE=1        # 执行还原/撤销而非写入
# WEQ_WRITE_PROFILE=1  # 允许写 profile 行
