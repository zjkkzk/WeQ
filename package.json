{
  "name": "weq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "QQ NT 本地聊天记录解密、导出、查看与年度报告",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @weq/desktop dev",
    "build": "pnpm run build:bot && pnpm --filter @weq/desktop build",
    "build:bot": "esbuild packages/bot/src/index.ts --bundle --platform=node --format=esm --external:ws --outfile=resources/bot-runtime/bot.mjs",
    "proto": "pnpm --filter @weq/protolab dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
